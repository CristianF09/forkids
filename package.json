{
  "name": "forkids-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "start": "concurrently \"npm:server\" \"npm:client\"",
    "server": "npm run dev --workspace=backend",
    "client": "npm start --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "postbuild": "rimraf backend/frontend && xcopy frontend\\build backend\\frontend /E /I /H /Y"
  },
  "devDependencies": {
    "@eslint/js": "^9.5.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.5.0",
    "eslint-plugin-react": "^7.34.3",
    "nodemon": "^3.1.4",
    "rimraf": "^5.0.7"
  },
  "dependencies": {
    "ajv": "^8.20.0"
  }
}
